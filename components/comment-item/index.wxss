.comment-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.comment-main {
  display: flex;
}

.comment-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.comment-user {
  font-size: 26rpx;
  font-weight: bold;
  color: #ffffff;
}

.comment-time {
  font-size: 22rpx;
  color: #666666;
}

.comment-text {
  font-size: 28rpx;
  color: #cccccc;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.comment-actions {
  display: flex;
  gap: 30rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.action-icon {
  font-size: 26rpx;
}

.action-text {
  font-size: 22rpx;
  color: #999999;
}

.action-btn.liked .action-text {
  color: #FF2D55;
}

.reply-list {
  margin-left: 92rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background-color: rgba(255, 255, 255, 0.03);
  border-radius: 10rpx;
}

.reply-item {
  margin-bottom: 10rpx;
}

.reply-item:last-child {
  margin-bottom: 0;
}

.reply-user {
  font-size: 24rpx;
  color: #FF2D55;
}

.reply-content {
  font-size: 24rpx;
  color: #cccccc;
}
