<view class="empty-container">
  <view class="empty-icon">{{icon}}</view>
  <text class="empty-text">{{text}}</text>
  <text class="empty-subtext" wx:if="{{subText}}">{{subText}}</text>
  <view class="empty-button" wx:if="{{showButton}}" bindtap="onButtonTap">
    <text class="button-text">{{buttonText}}</text>
  </view>
</view>
