.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 40rpx;
}

.empty-button {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #FF2D55 0%, #FF6B8A 100%);
  border-radius: 40rpx;
}

.button-text {
  font-size: 28rpx;
  color: #ffffff;
}
