.article-card {
  background-color: #1a1a1a;
  margin-bottom: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
}

.article-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.author-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
}

.publish-time {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.category-tag {
  font-size: 22rpx;
  color: #FF2D55;
  background-color: rgba(255, 45, 85, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.article-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.article-images {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
  gap: 10rpx;
}

.image-item {
  width: 32%;
}

.article-image {
  width: 100%;
  height: 200rpx;
  border-radius: 10rpx;
}

.article-desc {
  font-size: 28rpx;
  color: #cccccc;
  line-height: 1.8;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  text-overflow: ellipsis;
}

.article-music {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.05);
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.music-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.music-name {
  font-size: 24rpx;
  color: #999999;
}

.article-actions {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 22rpx;
  color: #999999;
}

.action-item.liked .action-text {
  color: #FF2D55;
}
