.user-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #1a1a1a;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-stats {
  display: flex;
  gap: 24rpx;
  margin-bottom: 8rpx;
}

.stat-item {
  font-size: 22rpx;
  color: #999999;
}

.user-bio {
  font-size: 24rpx;
  color: #666666;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  text-overflow: ellipsis;
}

.follow-btn {
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #FF2D55 0%, #FF6B8A 100%);
  border-radius: 30rpx;
}

.follow-text {
  font-size: 26rpx;
  color: #ffffff;
}
