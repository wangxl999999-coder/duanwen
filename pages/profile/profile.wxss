.profile-page {
  width: 100%;
  height: 100vh;
  background-color: #000000;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding-top: var(--status-bar-height);
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 20rpx;
  padding-right: 20rpx;
  background-color: rgba(0, 0, 0, 0.9);
}

.nav-blank {
  width: 80rpx;
}

.nav-left,
.nav-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon,
.settings-icon {
  font-size: 40rpx;
  color: #ffffff;
}

.nav-center {
  flex: 1;
  text-align: center;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.content-scroll {
  padding-top: calc(var(--status-bar-height) + 88rpx);
  min-height: 100vh;
}

.not-logged-in {
  padding: 40rpx 30rpx;
}

.login-prompt {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.05);
  padding: 30rpx;
  border-radius: 20rpx;
}

.avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.placeholder-icon {
  font-size: 48rpx;
  color: #666666;
}

.login-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.login-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.login-desc {
  font-size: 24rpx;
  color: #666666;
}

.arrow-icon {
  font-size: 36rpx;
  color: #666666;
}

.user-info-section {
  padding: 30rpx;
  border-bottom: 16rpx solid rgba(255, 255, 255, 0.03);
}

.user-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.1);
}

.user-detail {
  flex: 1;
  padding-top: 8rpx;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.gender-badge {
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 122, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gender-badge.female {
  background-color: rgba(255, 45, 85, 0.2);
}

.gender-icon {
  font-size: 24rpx;
  color: #007AFF;
}

.gender-badge.female .gender-icon {
  color: #FF2D55;
}

.username {
  font-size: 26rpx;
  color: #666666;
}

.action-group {
  display: flex;
  gap: 16rpx;
  margin-left: 16rpx;
}

.follow-btn,
.edit-btn,
.logout-btn {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
}

.follow-btn {
  background: linear-gradient(135deg, #FF2D55 0%, #FF6B8A 100%);
}

.follow-btn.followed {
  background-color: rgba(255, 255, 255, 0.1);
  background: none;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.follow-text,
.edit-text,
.logout-text {
  font-size: 24rpx;
  color: #ffffff;
}

.follow-btn.followed .follow-text {
  color: #999999;
}

.edit-btn {
  background-color: rgba(255, 255, 255, 0.1);
}

.logout-btn {
  background-color: rgba(255, 45, 85, 0.15);
}

.user-bio {
  margin-bottom: 20rpx;
}

.bio-text {
  font-size: 28rpx;
  color: #cccccc;
  line-height: 1.6;
}

.user-meta {
  display: flex;
  gap: 30rpx;
  margin-bottom: 30rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 28rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #999999;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-top: 24rpx;
  padding-bottom: 10rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 30rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.1);
}

.articles-section {
  
}

.tabs-row {
  display: flex;
  background-color: rgba(255, 255, 255, 0.02);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: #999999;
}

.tab-item.active .tab-text {
  color: #ffffff;
  font-weight: bold;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #FF2D55 0%, #FF6B8A 100%);
  border-radius: 2rpx;
}

.articles-list {
  padding: 20rpx;
}

.article-item {
  display: flex;
  background-color: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.article-cover {
  width: 200rpx;
  height: 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.article-cover.placeholder {
  background-color: rgba(255, 255, 255, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.placeholder-text {
  font-size: 48rpx;
  opacity: 0.5;
}

.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.article-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.article-meta {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.meta-item {
  font-size: 22rpx;
  color: #666666;
}

.empty-wrapper {
  padding-top: 80rpx;
}

.loading-wrapper {
  padding: 40rpx 0;
}

.no-more {
  padding: 30rpx 0;
  text-align: center;
}

.no-more-text {
  font-size: 24rpx;
  color: #666666;
}
