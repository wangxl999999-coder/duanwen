.index-page {
  width: 100%;
  height: 100vh;
  background-color: #000000;
  position: relative;
  overflow: hidden;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding-top: var(--status-bar-height);
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 30rpx;
  padding-right: 30rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0.8) 0%, transparent 100%);
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.category-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
}

.category-text {
  font-size: 26rpx;
  color: #ffffff;
}

.arrow-icon {
  font-size: 20rpx;
  color: #cccccc;
  transition: transform 0.3s;
}

.category-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
}

.panel-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.panel-content {
  position: absolute;
  top: calc(var(--status-bar-height) + 88rpx);
  right: 20rpx;
  background-color: #1a1a1a;
  border-radius: 20rpx;
  padding: 20rpx;
  min-width: 200rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.category-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.category-item:last-child {
  margin-bottom: 0;
}

.category-item.active {
  background-color: rgba(255, 45, 85, 0.15);
}

.category-icon {
  font-size: 32rpx;
}

.category-name {
  font-size: 28rpx;
  color: #ffffff;
}

.article-swiper {
  width: 100%;
  height: 100%;
}

.swiper-item {
  width: 100%;
  height: 100%;
}

.article-item {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: flex-end;
  padding-bottom: 60rpx;
}

.article-background {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(0deg, #000000 0%, rgba(0,0,0,0.6) 40%, rgba(0,0,0,0.2) 100%);
}

.article-info {
  position: relative;
  z-index: 10;
  flex: 1;
  padding-left: 30rpx;
  padding-right: 140rpx;
  padding-bottom: 40rpx;
}

.author-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.author-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.author-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
  margin-right: 20rpx;
}

.follow-btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #FF2D55 0%, #FF6B8A 100%);
  border-radius: 30rpx;
}

.follow-btn.followed {
  background-color: rgba(255, 255, 255, 0.1);
  background: none;
}

.follow-text {
  font-size: 24rpx;
  color: #ffffff;
}

.follow-btn.followed .follow-text {
  color: #999999;
}

.article-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.article-content {
  margin-bottom: 20rpx;
}

.images-preview {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  overflow-x: auto;
}

.preview-image {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.article-text {
  font-size: 28rpx;
  color: #e0e0e0;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
}

.music-row {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.08);
  padding: 16rpx 20rpx;
  border-radius: 40rpx;
  margin-top: 16rpx;
}

.music-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.music-icon.playing {
  animation: music-play 1s linear infinite;
}

@keyframes music-play {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.music-info {
  flex: 1;
}

.music-name {
  font-size: 26rpx;
  color: #ffffff;
}

.music-control {
  padding: 8rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
}

.control-text {
  font-size: 22rpx;
  color: #cccccc;
}

.action-sidebar {
  position: absolute;
  right: 20rpx;
  bottom: 80rpx;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-avatar {
  position: relative;
  margin-bottom: 8rpx;
}

.avatar-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.follow-badge {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #FF2D55 0%, #FF6B8A 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #ffffff;
}

.follow-badge.hidden {
  display: none;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.action-icon.liked .icon-text,
.action-icon.collected .icon-text {
  color: #FF2D55;
}

.icon-text {
  font-size: 56rpx;
}

.action-label {
  font-size: 24rpx;
  color: #ffffff;
}

.loading-container {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.empty-container {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
}
