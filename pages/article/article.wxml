<view class="article-page">
  <view class="custom-nav">
    <view class="nav-left" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="nav-center">
      <text class="nav-title">短文详情</text>
    </view>
    <view class="nav-right" bindtap="onTapShare">
      <text class="share-icon">⋯</text>
    </view>
  </view>

  <scroll-view class="content-scroll" scroll-y="true" bindscrolltolower="onScrollLower">
    <view class="loading-view" wx:if="{{loading}}">
      <loading text="加载中..."></loading>
    </view>

    <view class="article-container" wx:if="{{!loading && article}}">
      <view class="article-header">
        <view class="author-info" bindtap="onTapAuthor">
          <image class="author-avatar" src="{{article.author.avatar}}" mode="aspectFill"></image>
          <view class="author-detail">
            <text class="author-name">{{article.author.nickname}}</text>
            <text class="publish-time">{{article.createTime}}</text>
          </view>
        </view>
        <view class="follow-btn {{isFollowed ? 'followed' : ''}}" bindtap="onTapFollow">
          <text class="follow-text">{{isFollowed ? '已关注' : '+ 关注'}}</text>
        </view>
      </view>

      <view class="article-title">{{article.title}}</view>

      <view class="article-meta">
        <text class="category-tag">{{article.categoryName}}</text>
        <text class="view-count">{{article.viewCount}} 浏览</text>
      </view>

      <view class="article-images" wx:if="{{article.images.length > 0}}">
        <image class="article-image" wx:for="{{article.images}}" wx:key="index" src="{{item}}" mode="widthFix"></image>
      </view>

      <view class="article-content">
        <text class="content-text">{{article.content}}</text>
      </view>

      <view class="music-bar" wx:if="{{article.musicName}}" bindtap="toggleMusic">
        <view class="music-icon {{isPlaying ? 'playing' : ''}}">🎵</view>
        <view class="music-info">
          <text class="music-name">{{article.musicName}}</text>
          <text class="music-hint">点击{{isPlaying ? '暂停' : '播放'}}</text>
        </view>
        <view class="music-control">
          <text class="control-icon">{{isPlaying ? '⏸️' : '▶️'}}</text>
        </view>
      </view>

      <view class="action-bar">
        <view class="action-item" bindtap="onTapLike">
          <view class="action-icon {{isLiked ? 'active' : ''}}">
            <text class="icon-text">{{isLiked ? '❤️' : '🤍'}}</text>
          </view>
          <text class="action-text">{{likeCount}}</text>
        </view>
        <view class="action-item" bindtap="onTapCollect">
          <view class="action-icon {{isCollected ? 'active' : ''}}">
            <text class="icon-text">{{isCollected ? '⭐' : '☆'}}</text>
          </view>
          <text class="action-text">{{collectCount}}</text>
        </view>
        <view class="action-item" bindtap="onTapComment">
          <view class="action-icon">
            <text class="icon-text">💬</text>
          </view>
          <text class="action-text">{{commentCount}}</text>
        </view>
        <view class="action-item" bindtap="onTapShare">
          <view class="action-icon">
            <text class="icon-text">↗️</text>
          </view>
          <text class="action-text">分享</text>
        </view>
      </view>

      <view class="comment-section">
        <view class="section-header">
          <text class="section-title">评论 ({{commentCount}})</text>
          <view class="sort-btn">
            <text class="sort-text">最新</text>
          </view>
        </view>

        <view class="comment-list">
          <view class="empty-comment" wx:if="{{comments.length === 0}}">
            <text class="empty-icon">💬</text>
            <text class="empty-text">暂无评论，快来发表第一条评论吧~</text>
          </view>
          <comment-item wx:for="{{comments}}" wx:key="id" comment="{{item}}" bind:like="onCommentLike" bind:reply="onCommentReply"></comment-item>
        </view>

        <view class="loading-more" wx:if="{{commentLoading && hasMoreComments}}">
          <loading text="加载更多..."></loading>
        </view>

        <view class="no-more" wx:if="{{!hasMoreComments && comments.length > 0}}">
          <text class="no-more-text">没有更多评论了</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-bar">
    <view class="comment-input" bindtap="onTapComment">
      <text class="input-placeholder">说点什么...</text>
    </view>
    <view class="bottom-actions">
      <view class="bottom-action {{isLiked ? 'active' : ''}}" bindtap="onTapLike">
        <text class="bottom-icon">{{isLiked ? '❤️' : '🤍'}}</text>
      </view>
      <view class="bottom-action {{isCollected ? 'active' : ''}}" bindtap="onTapCollect">
        <text class="bottom-icon">{{isCollected ? '⭐' : '☆'}}</text>
      </view>
      <view class="bottom-action" bindtap="onTapShare">
        <text class="bottom-icon">↗️</text>
      </view>
    </view>
  </view>

  <view class="comment-modal" wx:if="{{showCommentInput}}" catchtouchmove="preventMove">
    <view class="modal-mask" bindtap="hideCommentInput"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="reply-to" wx:if="{{replyTo}}">回复 @{{replyTo.nickname}}</text>
        <text class="cancel-btn" bindtap="hideCommentInput">取消</text>
        <view class="send-btn {{commentContent ? 'active' : ''}}" bindtap="submitComment">
          <text class="send-text">发送</text>
        </view>
      </view>
      <textarea class="comment-textarea" value="{{commentContent}}" placeholder="{{replyTo ? '回复 ' + replyTo.nickname : '说点什么...'}}" bindinput="onCommentInput" maxlength="500" focus="{{showCommentInput}}" auto-height></textarea>
    </view>
  </view>
</view>
