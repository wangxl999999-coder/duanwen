.search-page {
  width: 100%;
  height: 100vh;
  background-color: #000000;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding-top: var(--status-bar-height);
  padding-bottom: 20rpx;
  background-color: rgba(0, 0, 0, 0.95);
  padding-left: 20rpx;
  padding-right: 20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  height: 72rpx;
  background-color: rgba(255, 255, 255, 0.08);
  border-radius: 36rpx;
  padding-left: 24rpx;
  padding-right: 10rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #ffffff;
}

.placeholder {
  color: #666666;
}

.search-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #FF2D55 0%, #FF6B8A 100%);
  border-radius: 30rpx;
  margin-left: 16rpx;
}

.search-text {
  font-size: 24rpx;
  color: #ffffff;
}

.content-scroll {
  padding-top: calc(var(--status-bar-height) + 92rpx);
  min-height: 100vh;
}

.category-section {
  padding: 30rpx;
  border-bottom: 16rpx solid rgba(255, 255, 255, 0.03);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.category-list {
  white-space: nowrap;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-right: 16rpx;
}

.category-item.active {
  background-color: rgba(255, 45, 85, 0.15);
}

.category-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 24rpx;
  color: #999999;
}

.category-item.active .category-name {
  color: #FF2D55;
}

.hot-users-section {
  padding: 30rpx;
  border-bottom: 16rpx solid rgba(255, 255, 255, 0.03);
}

.users-list {
  
}

.articles-section {
  padding: 30rpx;
}

.articles-list {
  
}

.empty-wrapper {
  padding-top: 100rpx;
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 24rpx;
  color: #666666;
}

.loading-wrapper {
  padding: 40rpx 0;
}

.no-more {
  padding: 30rpx 0;
  text-align: center;
}

.no-more-text {
  font-size: 24rpx;
  color: #666666;
}
